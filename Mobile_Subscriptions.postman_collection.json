{
  "info": {
    "name": "BDS Mobile Subscriptions",
    "description": "API collection to test mobile subscription registration and renewal flows.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "jwt_token",
      "value": "YOUR_MOBILE_JWT_TOKEN",
      "type": "string"
    },
    {
      "key": "annual_payment_id",
      "value": "PASTE_THE_ANNUAL_PAYMENT_ID_HERE",
      "type": "string"
    },
    {
      "key": "myfatoorah_payment_id",
      "value": "PASTE_THE_PAYMENT_ID_FROM_THE_BROWSER_URL",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Scenario 1: Registration Flow",
      "item": [
        {
          "name": "1. Mobile Register",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "fullNameEng", "value": "Test User", "type": "text" },
                { "key": "fullNameArb", "value": "Test User AR", "type": "text" },
                { "key": "email", "value": "mobile_test@example.com", "type": "text" },
                { "key": "password", "value": "Password123!", "type": "text" },
                { "key": "mobile", "value": "33334444", "type": "text" },
                { "key": "cpr", "value": "999999999", "type": "text" },
                { "key": "gender", "value": "male", "type": "text" },
                { "key": "nationality", "value": "Bahraini", "type": "text" },
                { "key": "category", "value": "dentist", "type": "text" },
                { "key": "workSector", "value": "private", "type": "text" },
                { "key": "employer", "value": "BDS", "type": "text" },
                { "key": "position", "value": "Doctor", "type": "text" },
                { "key": "specialty", "value": "General", "type": "text" },
                { "key": "address", "value": "Bahrain", "type": "text" },
                { "key": "membershipType", "value": "paid", "type": "text" },
                { "key": "subscriptionPlanId", "value": "f75eda23-e8c9-4c39-a0ee-ae772ef5ae79", "type": "text" },
                { "key": "typeOfApplication", "value": "new_membership", "type": "text" },
                { "key": "membershipDate", "value": "2024-03-28", "type": "text" },
                { "key": "id_card", "type": "file" },
                { "key": "personal_photo", "type": "file" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "auth", "register"]
            }
          }
        },
        {
          "name": "2. Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscription_id\": \"f75eda23-e8c9-4c39-a0ee-ae772ef5ae79\",\n  \"payment_id\": \"{{annual_payment_id}}\",\n  \"amount\": 70,\n  \"payment_type\": \"subscription_combined\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/payments/subscription/create-invoice",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "payments", "subscription", "create-invoice"]
            }
          }
        },
        {
          "name": "3. Execute Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{annual_payment_id}}\",\n  \"payment_method_id\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/payments/subscription/execute-payment",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "payments", "subscription", "execute-payment"]
            }
          }
        },
        {
          "name": "4. Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{myfatoorah_payment_id}}\",\n  \"type\": \"subscription\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/payments/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "payments", "confirm"]
            }
          }
        }
      ]
    },
    {
      "name": "Scenario 2: Renewal Flow",
      "item": [
        {
          "name": "1. Initiate Renewal",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/dashboard/subscriptions/renew",
              "host": ["{{base_url}}"],
              "path": ["api", "dashboard", "subscriptions", "renew"]
            }
          }
        },
        {
          "name": "2. Create Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subscription_id\": \"f75eda23-e8c9-4c39-a0ee-ae772ef5ae79\",\n  \"payment_id\": \"{{annual_payment_id}}\",\n  \"amount\": 70,\n  \"payment_type\": \"subscription_renewal\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/payments/subscription/create-invoice",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "payments", "subscription", "create-invoice"]
            }
          }
        },
        {
          "name": "3. Execute Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"payment_id\": \"{{annual_payment_id}}\",\n  \"payment_method_id\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/payments/subscription/execute-payment",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "payments", "subscription", "execute-payment"]
            }
          }
        },
        {
          "name": "4. Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{myfatoorah_payment_id}}\",\n  \"type\": \"subscription\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/mobile/payments/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "mobile", "payments", "confirm"]
            }
          }
        }
      ]
    }
  ]
}
